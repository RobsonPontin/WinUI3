<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ChildApp.ChildAppMainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ChildApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ChildApp">

    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
            <TextBlock Text="Child App 1"
                       FontSize="32"
                       HorizontalAlignment="Center" />
            <Button x:Name="SendRandomButton"
                    Content="Send Random Number"
                    Click="SendRandomButton_Click"
                    HorizontalAlignment="Center" />
            <TextBlock x:Name="RandomNumberText"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="IpcStatusText"
                       HorizontalAlignment="Center"
                       Foreground="Gray" />
        </StackPanel>
    </Grid>
</Window>
