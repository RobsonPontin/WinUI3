<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MultiApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MultiApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="MultiApp">

    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
            <TextBlock Text="MultiApp"
                       FontSize="24"
                       HorizontalAlignment="Center" />
            <Button x:Name="LaunchChildButton"
                    Content="Launch Child App"
                    Click="LaunchChildButton_Click"
                    HorizontalAlignment="Center" />
            <TextBlock x:Name="StatusText"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="IpcStatusText"
                       HorizontalAlignment="Center"
                       Foreground="Gray" />
            <TextBlock x:Name="ReceivedDataText"
                       HorizontalAlignment="Center"
                       FontSize="18" />
        </StackPanel>
    </Grid>
</Window>
