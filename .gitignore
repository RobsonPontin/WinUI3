################################################################################
# Unified .gitignore for all WinUI3 projects
# Covers: C++/WinRT, C#, .NET, MSIX packaging, NuGet, Visual Studio artifacts
################################################################################

# =============================================================================
# Visual Studio
# =============================================================================
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# =============================================================================
# Build outputs
# =============================================================================
[Dd]ebug/
[Rr]elease/
x64/
x86/
ARM/
ARM64/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# =============================================================================
# C++/WinRT generated files
# =============================================================================
Generated Files/

# =============================================================================
# NuGet packages (restored on build)
# =============================================================================
packages/
*.nupkg
!*.nupkg.metadata

# =============================================================================
# MSIX / AppX packaging artifacts
# =============================================================================
AppPackages/
BundleArtifacts/
*.appx
*.appxbundle
*.msix
*.msixbundle
*.appxupload
*.assets.cache

# =============================================================================
# Build caches & intermediate files
# =============================================================================
*.cache
*.tlog
*.log
*.obj
*.pch
*.pdb
*.ilk
*.exp
*.lib
*.iobj
*.ipdb
*.pgc
*.pgd
*.metagen
*.pri
*.winmd

# =============================================================================
# MIDL / COM generated files
# =============================================================================
dlldata.c
*_i.c
*_i.h
*_p.c

# =============================================================================
# .NET publish / test results
# =============================================================================
*.deps.json
*.runtimeconfig.json
publish/
TestResults/

# =============================================================================
# OS & editor files
# =============================================================================
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
*.swp
*.swo
*~